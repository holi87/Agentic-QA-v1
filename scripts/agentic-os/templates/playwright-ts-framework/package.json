{
  "name": "agentic-os-generated-suite",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone Playwright + TypeScript test suite generated by Agentic OS. Human-runnable outside the OS (issue #369).",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test api/",
    "test:ui": "playwright test ui/",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.13.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.10.0"
  },
  "dependencies": {
    "ajv": "^8.17.0"
  }
}
