# Agentic OS — Docker runtime environment (#353). Copy to `.env` and fill what
# you need; `docker-compose.yml` loads it (missing file is fine). NEVER commit
# a real `.env` — it is git-ignored. Refs to secrets only; see
# docs/docker-networking-contract.md (#355).

# Host port the dashboard is published on (container always listens on 8765).
AGENTIC_OS_DASHBOARD_PORT=8765

# --- SUT endpoint URLs for the generated test runner --------------------------
# Override config sut.web.url / sut.api.url for the runner. For a SUT on the
# host use host.docker.internal; for staging use its public URL.
# UI_BASE_URL=http://host.docker.internal:3000
# API_BASE_URL=http://host.docker.internal:3000/api

# --- SUT database / credentials (secret-bearing) ------------------------------
# The env var your config's sut.db.value / sut.credentials.value points at.
# Name it with a redaction keyword (PASSWORD/SECRET/TOKEN/CREDENTIAL) so it is
# scrubbed from logs — a bare DATABASE_URL is not auto-redacted yet (see #385).
# SUT_DB_PASSWORD=postgres://user:pass@host.docker.internal:5432/app
# TEST_USER_TOKEN=...

# --- Dashboard auth / write toggle (read-only by default) ---------------------
# AGENTIC_DASHBOARD_TOKEN=change-me
# AGENTIC_OS_DASHBOARD_WRITE_ENABLED=false

# --- Model / provider credentials --------------------------------------------
# Only needed for autonomy/workflows; the default `serve` dashboard needs none.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
